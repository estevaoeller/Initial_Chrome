{
  "manifest_version": 3,
  "name": "Página Inicial Personalizada",
  "version": "0.2.0",
  "description": "v0.2.0 de 08/07/2026 17:14 - Uma página inicial personalizada para otimizar o acesso a bookmarks e oferecer uma experiência visual única.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "bookmarks",
    "alarms",
    "notifications",
    "contextMenus"
  ],
  "host_permissions": [
    "https://api.track.toggl.com/*",
    "https://api.unsplash.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://api.open-meteo.com/*",
    "https://hnrss.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}
